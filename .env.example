# Ollama — LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2
OLLAMA_VISION_MODEL=gemma4:e4b

# ────────────────────────────────────────────────
# IMAGE_BACKEND: scegli il backend per la generazione immagine
#   "ollama"       → usa Ollama con OLLAMA_IMAGE_MODEL (es. flux2-klein)
#   "pollinations" → usa pollinations
#   "hf_inference" → usa HuggingFace Inference API
#   "onedrive"     → usa Onedrive
# ────────────────────────────────────────────────
IMAGE_BACKEND=pollinations

# Pollinations.ai
POLLINATIONS_MODEL=flux
#flux-realism

# Ollama image model (usato solo se IMAGE_BACKEND=ollama)
OLLAMA_IMAGE_MODEL=x/flux2-klein:4b-fp8

# OneDrive image extractor
# Path assoluto alla cartella OneDrive (adatta al tuo sistema)
ONEDRIVE_IMAGES_DIR=/Users/tuonome/OneDrive/Immagini/Campagne
# Modello VLM per la selezione (già su Ollama)
ONEDRIVE_VLM_MODEL=gemma4:12b

# Image output
IMAGE_OUTPUT_DIR=output/images
IMAGE_WIDTH=1024
IMAGE_HEIGHT=768

# App
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info

# Token to authenticate on Hugging Face
HF_TOKEN=<your_hugging_face_access_token>
# NOTE: when you create it, should be "finegrained" and the option "Read access to contents of all public gated repos you can access" must be flagged